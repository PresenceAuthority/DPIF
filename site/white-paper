/* ═══════════════════════════════════════
   TOKENS
═══════════════════════════════════════ */
:root{
  --mid:#0e0b1a;--mid1:#17122e;--mid2:#1f1840;
  --v:#4a3870;--vm:#6b5b8e;--vs:#9888c0;--vp:#f0ecf8;
  --gk:#3d7a5c;--gm:#5a9e7a;--gl:#7ab89a;--gp:#e8f4ef;
  --rm:#c9a8b8;--rl:#e8c8d8;
  --om:#c8b890;--ol:#d4c8a0;
  --tx:#ede8f8;--td:rgba(220,215,240,0.88);--tm:rgba(190,176,228,0.82);--ts:rgba(176,162,216,0.68);
  --br:rgba(152,136,192,0.12);--brm:rgba(152,136,192,0.22);--brh:rgba(152,136,192,0.38);
  --fd:'EB Garamond',Georgia,serif;--fb:'DM Sans',system-ui,sans-serif;--fm:'DM Mono',monospace;
  --gl-left:80px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);background:var(--mid);color:var(--td);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}

/* ═══════════════════════════════════════
   TOPBAR
═══════════════════════════════════════ */
.topbar{position:fixed;top:0;left:0;right:0;z-index:500;height:64px;display:flex;align-items:center;padding:0 var(--gl-left);background:rgba(14,11,26,0.88);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:0.5px solid var(--br);transition:background 0.3s}
.topbar.scrolled{background:rgba(14,11,26,0.97)}
.topbar-logo{display:flex;align-items:center;gap:12px;text-decoration:none;flex-shrink:0}
.topbar-mark{width:28px;height:28px;object-fit:contain}
.topbar-name{font-family:var(--fd);font-size:11px;letter-spacing:2.5px;color:#c8c0e0;text-transform:uppercase;line-height:1.2}
.topbar-nav{display:flex;align-items:center;margin-left:auto}
.topbar-link{padding:8px 16px;font-size:12.5px;font-weight:400;letter-spacing:0.4px;color:var(--tm);text-decoration:none;transition:all 0.2s}
.topbar-link:hover{color:var(--tx)}
.topbar-link-active{color:var(--vs)!important}
.topbar-cta{margin-left:20px;padding:8px 22px;font-family:var(--fb);font-size:12px;font-weight:500;letter-spacing:0.5px;background:var(--vm);color:#f0ecf8;border:none;border-radius:100px;cursor:pointer;transition:all 0.25s;text-decoration:none;white-space:nowrap}
.topbar-cta:hover{background:#7d6ca0;color:#fff;transform:translateY(-1px)}
.nav-toggle{display:none;background:none;border:none;color:var(--tm);cursor:pointer;padding:8px;margin-left:auto}
.nav-toggle svg{width:24px;height:24px;stroke:currentColor;fill:none;stroke-width:1.5}
.mob-menu{display:none;position:fixed;top:64px;right:0;bottom:0;width:280px;background:rgba(14,11,26,0.98);backdrop-filter:blur(24px);border-left:0.5px solid var(--br);padding:32px 28px;flex-direction:column;z-index:499;transform:translateX(100%);transition:transform 0.3s ease}
.mob-menu.open{transform:translateX(0)}
.mob-menu .topbar-link{display:block;padding:14px 0;font-size:15px;border-bottom:0.5px solid var(--br)}
.mob-menu .topbar-cta{margin:24px 0 0;text-align:center;display:block;padding:14px}

/* ═══════════════════════════════════════
   FOOTER
═══════════════════════════════════════ */
.footer{border-top:0.5px solid var(--br);padding:64px 0 40px;background:var(--mid)}
.footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
.footer-brand{font-family:var(--fd);font-size:12px;letter-spacing:2px;color:#c8c0e0;text-transform:uppercase;margin-bottom:12px}
.footer-desc{font-size:13px;color:var(--ts);line-height:1.7;max-width:280px}
.footer-heading{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(176,162,216,0.55);margin-bottom:16px}
.footer-link{display:block;padding:4px 0;font-size:13px;color:rgba(190,176,228,0.65);text-decoration:none;transition:color 0.2s}
.footer-link:hover{color:var(--tx)}
.footer-bottom{padding-top:24px;border-top:0.5px solid var(--br);display:flex;justify-content:space-between;align-items:center}
.footer-copy{font-size:11px;color:rgba(176,162,216,0.48)}
.footer-ver{font-family:var(--fm);font-size:10px;color:rgba(176,162,216,0.4)}

/* ═══════════════════════════════════════
   SHARED
═══════════════════════════════════════ */
.rail{max-width:920px;margin:0 auto;padding:0 var(--gl-left)}
.rail-w{max-width:1080px;margin:0 auto;padding:0 var(--gl-left)}
.section-label{font-size:10px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--vs);display:flex;align-items:center;gap:12px;margin-bottom:20px}
.section-label::before{content:'';width:32px;height:1px;background:var(--vs);flex-shrink:0}
.btn{display:inline-block;font-family:var(--fb);font-weight:500;letter-spacing:0.5px;border-radius:100px;text-decoration:none;transition:all 0.25s;cursor:pointer;text-align:center}
.btn-p{background:var(--vm);color:#f0ecf8;border:none}
.btn-p:hover{background:#7d6ca0;color:#fff;transform:translateY(-1px)}
.btn-g{background:transparent;color:var(--vs);border:0.5px solid var(--brm)}
.btn-g:hover{border-color:var(--brh);color:var(--tx)}
.btn-lg{padding:14px 32px;font-size:14px}
.btn-sm{padding:9px 20px;font-size:12px}

/* ═══════════════════════════════════════
   PAGE HERO / DOCUMENT HEADER
═══════════════════════════════════════ */
.doc-header{background:var(--mid1);border-bottom:0.5px solid var(--br);padding:88px 0 64px;margin-top:64px}
.doc-header-inner{max-width:920px;margin:0 auto;padding:0 var(--gl-left)}
.doc-eyebrow{display:flex;align-items:center;gap:12px;margin-bottom:18px}
.doc-type-badge{display:inline-flex;align-items:center;background:rgba(152,136,192,0.1);border:0.5px solid var(--br);border-radius:4px;padding:5px 12px;font-family:var(--fm);font-size:10px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;color:var(--vs)}
.doc-header h1{font-family:var(--fd);font-weight:400;font-size:clamp(34px,4.5vw,56px);color:var(--tx);line-height:1.1;margin-bottom:14px}
.doc-header h1 em{font-style:italic;background:linear-gradient(135deg,#9888c0,#7ab89a,#c9a8b8,#c8b890);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.doc-subtitle{font-family:var(--fb);font-size:17px;font-weight:300;color:var(--tm);margin-bottom:40px;line-height:1.55;max-width:600px}
.doc-meta-bar{display:flex;flex-wrap:wrap;gap:32px;padding-top:24px;border-top:0.5px solid var(--br)}
.doc-meta-item{display:flex;flex-direction:column;gap:4px}
.doc-meta-label{font-family:var(--fm);font-size:9px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--ts)}
.doc-meta-value{font-family:var(--fm);font-size:12px;color:var(--vs)}
.doc-meta-value a{color:var(--vs)}
.doc-meta-value a:hover{color:var(--tx)}

/* PDF access strip */
.pdf-strip{background:var(--mid2);border-bottom:0.5px solid var(--br);padding:16px 0}
.pdf-strip-inner{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.pdf-info{display:flex;flex-direction:column;gap:3px}
.pdf-filename{font-family:var(--fm);font-size:12.5px;color:var(--tx)}
.pdf-filemeta{font-family:var(--fm);font-size:10px;color:var(--ts)}

/* ═══════════════════════════════════════
   MAIN LAYOUT — sidebar + content
═══════════════════════════════════════ */
.doc-main{padding:64px 0 96px}
.doc-layout{display:grid;grid-template-columns:210px 1fr;gap:64px;align-items:start}

/* Sidebar */
.doc-sidebar{position:sticky;top:88px;max-height:calc(100vh - 120px);overflow-y:auto;display:flex;flex-direction:column;gap:0}
.sidebar-heading{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(176,162,216,0.45);margin-bottom:14px}
.sidebar-nav{display:flex;flex-direction:column;gap:1px;margin-bottom:20px}
.sidebar-link{font-family:var(--fm);font-size:11px;color:var(--ts);padding:7px 10px;border-radius:4px;transition:all 0.2s;text-decoration:none;line-height:1.35;display:block}
.sidebar-link:hover,.sidebar-link.active{color:var(--tx);background:rgba(152,136,192,0.09)}
.sidebar-link.active{color:var(--vs)}
.sidebar-divider{height:0.5px;background:var(--br);margin:16px 0}
.sidebar-dl{display:flex;flex-direction:column;gap:10px}

/* Document body */
.doc-body{min-width:0}
.doc-notice{background:var(--mid2);border:0.5px solid var(--brm);border-left:2px solid var(--vs);border-radius:0 8px 8px 0;padding:18px 22px;margin-bottom:48px}
.doc-notice p{font-family:var(--fb);font-size:13.5px;color:var(--tm);margin:0;line-height:1.7}
.doc-notice strong{color:var(--tx)}

/* Sections */
.doc-section{margin-bottom:56px;padding-bottom:56px;border-bottom:0.5px solid var(--br)}
.doc-section:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.doc-section h2{font-family:var(--fd);font-weight:400;font-size:clamp(24px,2.8vw,32px);color:var(--tx);margin-bottom:20px;line-height:1.2}
.doc-section p{font-family:var(--fb);font-size:15px;color:var(--td);line-height:1.8;margin-bottom:14px}
.doc-section p:last-child{margin-bottom:0}
.doc-section strong{font-weight:500;color:var(--tx)}

/* Scope boundary lists */
.scope-cols{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:20px 0}
.scope-col-head{font-family:var(--fm);font-size:9px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:10px}
.scope-col-head.in{color:var(--gl)}
.scope-col-head.out{color:var(--rm)}
.scope-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px}
.scope-list li{font-family:var(--fb);font-size:13.5px;color:var(--td);padding-left:16px;position:relative;line-height:1.6}
.scope-list li::before{position:absolute;left:0;font-size:11px;top:2px}
.scope-list.in li::before{content:'✓';color:var(--gl)}
.scope-list.out li::before{content:'×';color:var(--rm)}

/* Control category table */
.cat-table{width:100%;border-collapse:collapse;margin:20px 0}
.cat-table th{font-family:var(--fm);font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--vs);padding:8px 14px;border-bottom:0.5px solid var(--brm);text-align:left}
.cat-table td{font-family:var(--fb);font-size:13.5px;color:var(--td);padding:10px 14px;border-bottom:0.5px solid var(--br);vertical-align:top;line-height:1.55}
.cat-table tr:last-child td{border-bottom:none}
.cat-table td:first-child{font-family:var(--fm);font-size:11px;color:var(--vs);white-space:nowrap}
.cat-table td strong{color:var(--tx);font-weight:500}
.cat-table td em{color:var(--ts);font-style:normal;font-size:12.5px}

/* Control classification block */
.ctrl-classify{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:20px 0}
.ctrl-block{background:var(--mid2);border:0.5px solid var(--br);border-radius:10px;padding:20px 22px}
.ctrl-block-label{font-family:var(--fm);font-size:9px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:8px}
.ctrl-block-label.cpc{color:var(--rm)}
.ctrl-block-label.spc{color:var(--om)}
.ctrl-block-count{font-family:var(--fd);font-size:36px;color:var(--tx);line-height:1;margin-bottom:6px}
.ctrl-block-desc{font-family:var(--fb);font-size:13px;color:var(--td);line-height:1.6}
.ctrl-block-ids{font-family:var(--fm);font-size:10px;color:var(--ts);margin-top:8px;line-height:1.7}

/* Outcomes table */
.outcomes-table{width:100%;border-collapse:collapse;margin:20px 0}
.outcomes-table th{font-family:var(--fm);font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--vs);padding:8px 14px;border-bottom:0.5px solid var(--brm);text-align:left}
.outcomes-table td{font-family:var(--fb);font-size:13.5px;color:var(--td);padding:10px 14px;border-bottom:0.5px solid var(--br);vertical-align:top;line-height:1.55}
.outcomes-table tr:last-child td{border-bottom:none}
.result-pass{font-family:var(--fm);font-size:11px;font-weight:600;color:var(--gl)}
.result-cond{font-family:var(--fm);font-size:11px;font-weight:600;color:var(--om)}
.result-fail{font-family:var(--fm);font-size:11px;font-weight:600;color:var(--rm)}

/* Instrument list */
.inst-list{display:flex;flex-direction:column;gap:10px;margin:20px 0}
.inst-item{background:var(--mid2);border:0.5px solid var(--br);border-radius:10px;padding:16px 20px;display:flex;gap:16px;align-items:flex-start;transition:border-color 0.2s}
.inst-item:hover{border-color:var(--brm)}
.inst-num{font-family:var(--fm);font-size:10px;color:var(--vs);flex-shrink:0;min-width:28px;padding-top:1px}
.inst-name{font-family:var(--fd);font-size:16px;color:var(--tx);margin-bottom:3px}
.inst-version{font-family:var(--fm);font-size:10px;color:var(--ts);margin-left:8px;font-style:normal}
.inst-desc{font-family:var(--fb);font-size:13px;color:var(--td);line-height:1.6}
.inst-dl{margin-top:8px}
.inst-dl a{font-family:var(--fm);font-size:10px;color:var(--vs);text-decoration:none;letter-spacing:0.5px}
.inst-dl a:hover{color:var(--tx)}

/* Bottom CTA */
.bottom-cta{background:var(--mid1);border:0.5px solid var(--br);border-radius:16px;padding:40px;margin-top:56px;display:flex;align-items:center;justify-content:space-between;gap:32px;flex-wrap:wrap}
.bottom-cta-text h3{font-family:var(--fd);font-weight:400;font-size:26px;color:var(--tx);margin-bottom:8px}
.bottom-cta-text p{font-family:var(--fb);font-size:14px;color:var(--tm);line-height:1.65;max-width:440px}
.bottom-cta-actions{display:flex;flex-direction:column;gap:10px;flex-shrink:0}

/* ═══════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════ */
@media(max-width:900px){
  .doc-layout{grid-template-columns:1fr}
  .doc-sidebar{position:static;background:var(--mid2);border:0.5px solid var(--br);border-radius:10px;padding:22px 24px;max-height:none;margin-bottom:48px}
  .sidebar-nav{display:grid;grid-template-columns:repeat(2,1fr);gap:2px}
  .sidebar-dl{flex-direction:row;flex-wrap:wrap}
  .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
  .ctrl-classify{grid-template-columns:1fr 1fr}
  .scope-cols{grid-template-columns:1fr 1fr}
}
@media(max-width:640px){
  :root{--gl-left:24px}
  .topbar{padding:0 24px}
  .topbar-nav,.topbar-cta{display:none}
  .nav-toggle{display:flex}
  .mob-menu{display:flex}
  .doc-header{padding:64px 0 48px}
  .sidebar-nav{grid-template-columns:1fr}
  .sidebar-dl{flex-direction:column}
  .footer-grid{grid-template-columns:1fr;gap:24px}
  .pdf-strip-inner{flex-direction:column;gap:12px}
  .ctrl-classify{grid-template-columns:1fr}
  .scope-cols{grid-template-columns:1fr}
  .bottom-cta{flex-direction:column;padding:28px}
  .bottom-cta-actions{width:100%}
  .bottom-cta-actions .btn{width:100%}
}
@media(max-width:400px){
  :root{--gl-left:16px}
  .topbar{padding:0 16px}
}
</style>
</head>
